{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://krishi-sakhi-backend-f5ln.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://krishi-sakhi-backend-f5ln.onrender.com/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
